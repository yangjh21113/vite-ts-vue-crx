{
  "name": "测试录屏",
  "description": "Records the current tab in an offscreen document.",
  "version": "1",
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "action": {
    "default_icon": "icons/app.png"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": ["tabs","activeTab", "contextMenus", "tabCapture", "offscreen", "sidePanel"],
  "side_panel": {
    "default_path": "index.html"
  }
}
